{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autodemapper.dev/schemas/baseline.json",
  "title": "AutoDemapper Baseline Schema",
  "description": "Schema for Stage 4 output: Baseline test run results",
  "type": "object",
  "required": ["version", "timestamp", "testRun", "baselineEstablished"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "testRun": {
      "type": "object",
      "required": ["command", "totalTests", "passed", "failed", "skipped"],
      "properties": {
        "command": {
          "type": "string",
          "description": "Test command executed"
        },
        "totalTests": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" },
        "duration": {
          "type": "string",
          "description": "Duration in HH:MM:SS format"
        }
      }
    },
    "baselineEstablished": {
      "type": "boolean",
      "description": "True if all tests passed"
    },
    "failedTests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["testName", "error"],
        "properties": {
          "testName": { "type": "string" },
          "error": { "type": "string" },
          "stackTrace": { "type": "string" }
        }
      }
    }
  }
}
