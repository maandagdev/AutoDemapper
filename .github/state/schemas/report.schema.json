{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autodemapper.dev/schemas/report.json",
  "title": "AutoDemapper Report Schema",
  "description": "Schema for Stage 7 output: Final migration report",
  "type": "object",
  "required": ["version", "timestamp", "summary", "commitStrategy", "automapperRemovalReady"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "required": ["totalMappings", "successfullyMigrated", "requiresManualWork", "testsWritten", "callSitesUpdated"],
      "properties": {
        "totalMappings": { "type": "integer" },
        "successfullyMigrated": { "type": "integer" },
        "requiresManualWork": { "type": "integer" },
        "testsWritten": { "type": "integer" },
        "callSitesUpdated": { "type": "integer" },
        "profilesProcessed": { "type": "integer" },
        "duration": {
          "type": "string",
          "description": "Total pipeline duration"
        }
      }
    },
    "commitStrategy": {
      "type": "string",
      "enum": ["atomic", "per-profile", "per-mapping", "per-tier"],
      "description": "Recommended commit strategy"
    },
    "commits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["message", "files"],
        "properties": {
          "message": { "type": "string" },
          "files": {
            "type": "array",
            "items": { "type": "string" }
          },
          "mappingIds": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "automapperRemovalReady": {
      "type": "boolean",
      "description": "True if AutoMapper can be completely removed"
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Issues preventing complete AutoMapper removal"
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["performance", "maintainability", "testing", "cleanup"]
          },
          "description": { "type": "string" }
        }
      }
    }
  }
}
