{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autodemapper.dev/schemas/validation.json",
  "title": "AutoDemapper Validation Schema",
  "description": "Schema for Stage 6 output: Post-migration validation results",
  "type": "object",
  "required": ["version", "timestamp", "testRun", "regressions", "validationPassed"],
  "properties": {
    "version": {
      "type": "string",
      "const": "1.0"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "testRun": {
      "type": "object",
      "required": ["command", "totalTests", "passed", "failed", "skipped"],
      "properties": {
        "command": { "type": "string" },
        "totalTests": { "type": "integer" },
        "passed": { "type": "integer" },
        "failed": { "type": "integer" },
        "skipped": { "type": "integer" },
        "duration": { "type": "string" }
      }
    },
    "regressions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["testName", "expected", "actual", "mappingId"],
        "properties": {
          "testName": { "type": "string" },
          "expected": { "type": "string" },
          "actual": { "type": "string" },
          "mappingId": {
            "type": "string",
            "format": "uuid"
          },
          "investigation": {
            "type": "string",
            "description": "Analysis of the regression"
          },
          "fixAttempts": {
            "type": "integer",
            "description": "Number of fix attempts made"
          }
        }
      }
    },
    "validationPassed": {
      "type": "boolean"
    },
    "comparisonToBaseline": {
      "type": "object",
      "properties": {
        "baselineTotal": { "type": "integer" },
        "currentTotal": { "type": "integer" },
        "newTests": { "type": "integer" },
        "removedTests": { "type": "integer" }
      }
    }
  }
}
